APP_ENV=production

# Populated from AWS SSM Parameter Store at deploy time.
POSTGRES_USER=vestrs
POSTGRES_PASSWORD=__from_ssm__
POSTGRES_DB=vestrs_production

# Application secrets (populated by deploy.sh from SSM).
JWT_SECRET=__from_ssm__

# Image tag pulled from GHCR. Floating tags: `staging`, `production`.
# Pin to a SHA (e.g. `sha-abc1234`) to roll back without retagging.
VESTRS_TAG=production

# Caddy / TLS.
ACME_EMAIL=ops@manishlamba.com

COMPOSE_PROJECT_NAME=vestrs-production
PUBLIC_API_HOST=api.vestrs.manishlamba.com
PUBLIC_WEB_HOST=vestrs.manishlamba.com

# Observability.
#
# Self-hosted Grafana (slice 23, default) reads these. Empty
# COMPOSE_PROFILES leaves the cloud-obs grafana-agent out of the graph
# and runs prometheus + grafana on-box at
# https://monitoring.vestrs.manishlamba.com. The admin password is
# sourced from SSM (/vestrs/production/GRAFANA_ADMIN_PASSWORD) at
# deploy time.
COMPOSE_PROFILES=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__from_ssm__

# Alertmanager email receiver (slice 25). Generate a Gmail App Password
# at https://myaccount.google.com/apppasswords and store it in SSM as
# /vestrs/production/ALERTMANAGER_SMTP_PASSWORD. The username is the
# sending Gmail address; the recipient is who gets paged.
ALERTMANAGER_SMTP_HOST=smtp.gmail.com:587
ALERTMANAGER_SMTP_USERNAME=manishlamba002@gmail.com
ALERTMANAGER_SMTP_PASSWORD=__from_ssm__
ALERTMANAGER_EMAIL_TO=manishlamba002@gmail.com

# Transactional email (slice 26) — welcome email on signup. Reuses the
# same Gmail App Password as alertmanager. Empty SMTP_HOST disables
# sending entirely (signup still succeeds, audit log records as normal).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=manishlamba002@gmail.com
SMTP_PASSWORD=__from_ssm__
SMTP_FROM_ADDRESS=manishlamba002@gmail.com
SMTP_FROM_NAME=Vestrs
PUBLIC_WEB_URL=https://vestrs.manishlamba.com

# Optional Grafana Cloud target. Set COMPOSE_PROFILES=cloud-obs to ship
# to Cloud instead of the on-box stack. Mutually exclusive — running
# both stores duplicates metrics against the same exporters.
GRAFANA_CLOUD_PROM_URL=
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_API_KEY=
