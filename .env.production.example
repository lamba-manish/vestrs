APP_ENV=production

# Populated from AWS SSM Parameter Store at deploy time.
POSTGRES_USER=vestrs
POSTGRES_PASSWORD=__from_ssm__
POSTGRES_DB=vestrs_production

# Application secrets (populated by deploy.sh from SSM).
JWT_SECRET=__from_ssm__

# Image tag pulled from GHCR. Floating tags: `staging`, `production`.
# Pin to a SHA (e.g. `sha-abc1234`) to roll back without retagging.
VESTRS_TAG=production

# Caddy / TLS.
ACME_EMAIL=ops@manishlamba.com

COMPOSE_PROJECT_NAME=vestrs-production
PUBLIC_API_HOST=api.vestrs.manishlamba.com
PUBLIC_WEB_HOST=vestrs.manishlamba.com
