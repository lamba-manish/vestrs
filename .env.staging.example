APP_ENV=staging

# Populated from AWS SSM Parameter Store at deploy time.
# These names are placeholders so docker-compose.staging.yml resolves.
POSTGRES_USER=vestrs
POSTGRES_PASSWORD=__from_ssm__
POSTGRES_DB=vestrs_staging

# Application secrets (populated by deploy.sh from SSM).
JWT_SECRET=__from_ssm__

# Image tag pulled from GHCR. Floating tags: `staging`, `production`.
# Pin to a SHA (e.g. `sha-abc1234`) to roll back without retagging.
VESTRS_TAG=staging

# Caddy / TLS.
ACME_EMAIL=ops@manishlamba.com

COMPOSE_PROJECT_NAME=vestrs-staging
PUBLIC_API_HOST=staging-api.vestrs.manishlamba.com
PUBLIC_WEB_HOST=staging.vestrs.manishlamba.com

# Observability — fill in once the Grafana Cloud stack is provisioned
# (see README "Observability"). Setting COMPOSE_PROFILES=cloud-obs
# enables the grafana-agent service that ships metrics + logs.
COMPOSE_PROFILES=
GRAFANA_CLOUD_PROM_URL=
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_API_KEY=
