APP_ENV=staging

# Populated from AWS SSM Parameter Store at deploy time.
# These names are placeholders so docker-compose.staging.yml resolves.
POSTGRES_USER=vestrs
POSTGRES_PASSWORD=__from_ssm__
POSTGRES_DB=vestrs_staging

COMPOSE_PROJECT_NAME=vestrs-staging
PUBLIC_API_HOST=staging-api.vestrs.manishlamba.com
PUBLIC_WEB_HOST=staging.vestrs.manishlamba.com
